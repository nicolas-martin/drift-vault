# =============================================================================
# Delta-Neutral Vault Keeper Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Solana RPC Configuration
# -----------------------------------------------------------------------------
# Use a dedicated RPC provider for mainnet (Helius, Quicknode, Triton, etc.)
RPC_URL=

# -----------------------------------------------------------------------------
# Wallet & Vault Configuration
# -----------------------------------------------------------------------------
# Path to the delegate keypair JSON file (must have delegate authority on vault)
DELEGATE_KEYPAIR_PATH=./keypairs/delegate.json

# The vault's public key address (run scripts/init-vault.sh to create one)
VAULT_ADDRESS=

# Drift environment: mainnet-beta | devnet
DRIFT_ENV=mainnet-beta

# Jupiter API key (required - get a free key at https://portal.jup.ag)
JUPITER_API_KEY=

# -----------------------------------------------------------------------------
# Strategy Parameters
# -----------------------------------------------------------------------------
# Minimum funding rate (annualized %) to open a position
# Only enter positions when funding rate exceeds this threshold
MIN_FUNDING_RATE_THRESHOLD=10

# Threshold (annualized %) at which to close positions due to negative funding
# Close position if funding turns against us by more than this amount
NEGATIVE_FUNDING_CLOSE_THRESHOLD=-5

# Maximum position size in USD for any single market
MAX_POSITION_SIZE_USD=5

# Rebalance threshold percentage
# Trigger rebalance when spot/perp ratio drifts by more than this %
REBALANCE_THRESHOLD_PCT=5

# Minimum health ratio to maintain (0-100)
# Close positions if account health drops below this threshold
HEALTH_MIN_THRESHOLD=20

# Main loop interval in milliseconds
LOOP_INTERVAL_MS=60000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: error | warn | info | debug
LOG_LEVEL=info
